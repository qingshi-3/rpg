[gd_resource type="BehaviorTree" load_steps=18 format=3]

[ext_resource type="Script" path="res://scripts/ai/limbo_tasks/battle/select_battle_target.gd" id="1_select"]
[ext_resource type="Script" path="res://scripts/ai/limbo_tasks/battle/can_strike_battle_target.gd" id="2_canstrike"]
[ext_resource type="Script" path="res://scripts/ai/limbo_tasks/battle/emit_battle_intent.gd" id="3_emit"]
[ext_resource type="Script" path="res://scripts/ai/limbo_tasks/battle/has_ranged_battle_ability.gd" id="4_ranged"]

[sub_resource type="BlackboardPlan" id="BlackboardPlan_enemy_basic"]
var/target_id/name = &"target_id"
var/target_id/type = 4
var/target_id/value = ""
var/ability_id/name = &"ability_id"
var/ability_id/type = 4
var/ability_id/value = ""
var/intent_power/name = &"intent_power"
var/intent_power/type = 2
var/intent_power/value = 0

[sub_resource type="BTAction" id="BTAction_select_ranged"]
script = ExtResource("1_select")
mode = "nearest_hostile"
target_var = &"target_id"

[sub_resource type="BTCondition" id="BTCondition_has_ranged"]
script = ExtResource("4_ranged")
ability_var = &"ability_id"

[sub_resource type="BTAction" id="BTAction_emit_ranged"]
script = ExtResource("3_emit")
template_id = &"ranged_pressure"
power_var = &"intent_power"

[sub_resource type="BTSequence" id="BTSequence_ranged"]
custom_name = "Ranged pressure when primary ability reaches beyond melee"
children = [SubResource("BTAction_select_ranged"), SubResource("BTCondition_has_ranged"), SubResource("BTAction_emit_ranged")]

[sub_resource type="BTAction" id="BTAction_select_direct"]
script = ExtResource("1_select")
mode = "nearest_hostile"
target_var = &"target_id"

[sub_resource type="BTCondition" id="BTCondition_can_strike"]
script = ExtResource("2_canstrike")
target_var = &"target_id"
ability_var = &"ability_id"

[sub_resource type="BTAction" id="BTAction_emit_direct"]
script = ExtResource("3_emit")
template_id = &"direct_strike"
power_var = &"intent_power"

[sub_resource type="BTSequence" id="BTSequence_direct"]
custom_name = "Direct strike when target is valid"
children = [SubResource("BTAction_select_direct"), SubResource("BTCondition_can_strike"), SubResource("BTAction_emit_direct")]

[sub_resource type="BTAction" id="BTAction_select_pressure"]
script = ExtResource("1_select")
mode = "nearest_hostile"
target_var = &"target_id"

[sub_resource type="BTAction" id="BTAction_emit_pressure"]
script = ExtResource("3_emit")
template_id = &"melee_pressure"
power_var = &"intent_power"

[sub_resource type="BTSequence" id="BTSequence_pressure"]
custom_name = "Pressure nearest target"
children = [SubResource("BTAction_select_pressure"), SubResource("BTAction_emit_pressure")]

[sub_resource type="BTAction" id="BTAction_emit_hold"]
script = ExtResource("3_emit")
template_id = &"hold"
reason = "No available target"

[sub_resource type="BTSelector" id="BTSelector_root"]
custom_name = "Enemy basic intent"
children = [SubResource("BTSequence_ranged"), SubResource("BTSequence_direct"), SubResource("BTSequence_pressure"), SubResource("BTAction_emit_hold")]

[resource]
description = "First project-authored LimboAI tree for battle intent selection. It emits intent IDs through the C# facade; C# still validates and resolves actions."
blackboard_plan = SubResource("BlackboardPlan_enemy_basic")
root_task = SubResource("BTSelector_root")
