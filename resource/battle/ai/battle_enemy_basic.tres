[resource]
description = "First project-authored LimboAI tree for battle intent selection. It emits intent IDs through the C# facade; C# still validates and resolves actions."
blackboard_plan = SubResource("BlackboardPlan_enemy_basic")
root_task = SubResource("BTSelector_root")
