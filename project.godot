; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="rpg"
run/main_scene="res://scenes/world/StrategicWorldRoot.tscn"
config/features=PackedStringArray("4.5", "C#", "GL Compatibility")
run/max_fps=60
config/icon="res://icon.svg"

[autoload]

PerformanceDebugOverlay="*res://scenes/debug/PerformanceDebugOverlay.tscn"

[display]

window/size/viewport_width=1960
window/size/viewport_height=1080
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[dotnet]

project/assembly_name="rpg"

[file_customization]

folder_colors={
"res://assets/": "red",
"res://docs/": "yellow",
"res://src/": "green"
}

[rendering]

textures/canvas_textures/default_texture_filter=0
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
